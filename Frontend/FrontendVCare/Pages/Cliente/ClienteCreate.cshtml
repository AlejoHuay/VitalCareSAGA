@page
@model FrontendVCare.Pages.ClienteCreateModel
@{
    ViewData["Title"] = "Nuevo Cliente";
}

<section class="client-form-page">
    <div class="form-shell">
        <div class="form-header bg-success text-white">
            <h1>Nuevo Cliente</h1>
            <p>Completa los datos para registrar un cliente.</p>
        </div>

        <form method="post" asp-page-handler="CrearCliente" class="form-body" id="clienteForm">
            <div class="mb-4">
                <label class="form-label fw-bold text-muted d-block mb-3">Tipo de registro</label>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="choice-box" for="tipoClienteFormal">
                            <input asp-for="Cliente.EsConsumidorFinal" id="tipoClienteFormal" type="radio" value="false" class="form-check-input me-2" />
                            <span class="fw-semibold d-block mb-1">Cliente con datos fiscales</span>
                            <span class="text-muted small">Registra NIT, razon social y correo electronico.</span>
                        </label>
                    </div>

                    <div class="col-md-6">
                        <label class="choice-box" for="tipoConsumidorFinal">
                            <input asp-for="Cliente.EsConsumidorFinal" id="tipoConsumidorFinal" type="radio" value="true" class="form-check-input me-2" />
                            <span class="fw-semibold d-block mb-1">Consumidor Final</span>
                            <span class="text-muted small">NIT = CF y razon social = Consumidor Final.</span>
                        </label>
                    </div>
                </div>
            </div>

            <div id="bloqueConsumidorFinal" class="alert alert-success border-0 mb-4" style="display:none;">
                Se registrara el cliente como <strong>Consumidor Final</strong>.
            </div>

            <div id="datosClienteFiscal">
                <div class="form-floating mb-3">
                    <input asp-for="Cliente.Nit" class="form-control" placeholder="NIT" inputmode="numeric" />
                    <label>NIT / CI</label>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Cliente.RazonSocial" class="form-control" placeholder="Razon Social" minlength="3" maxlength="45" pattern="[A-Za-zÁÉÍÓÚÜÑáéíóúüñ ]+" title="Solo se permiten letras y espacios." required />
                    <label>Razon Social / Nombre Completo</label>
                </div>

                <div id="correoElectronicoGroup" class="form-floating mb-3">
                    <input asp-for="Cliente.CorreoElectronico" type="email" class="form-control" placeholder="Correo Electronico" maxlength="45" />
                    <label>Correo Electronico</label>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.MensajeError))
            {
                <div class="alert alert-danger">@Model.MensajeError</div>
            }

            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                <a asp-page="Cliente" class="btn btn-secondary px-4">Volver</a>
                <button type="submit" class="btn btn-success px-5 fw-bold" id="guardarClienteBtn">
                    Guardar
                </button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            const opcionFormal = document.getElementById('tipoClienteFormal');
            const opcionConsumidorFinal = document.getElementById('tipoConsumidorFinal');
            const bloqueInformativo = document.getElementById('bloqueConsumidorFinal');
            const contenedor = document.getElementById('datosClienteFiscal');
            const correoGroup = document.getElementById('correoElectronicoGroup');
            const form = document.getElementById('clienteForm');
            const guardarBtn = document.getElementById('guardarClienteBtn');
            const nit = document.getElementById('Cliente_Nit');
            const razonSocial = document.getElementById('Cliente_RazonSocial');
            const correoElectronico = document.getElementById('Cliente_CorreoElectronico');

            const actualizarFormulario = () => {
                const esConsumidorFinal = opcionConsumidorFinal.checked;
                bloqueInformativo.style.display = esConsumidorFinal ? '' : 'none';
                contenedor.style.display = esConsumidorFinal ? 'none' : '';
                correoGroup.style.display = esConsumidorFinal ? 'none' : '';
                razonSocial.required = !esConsumidorFinal;

                if (esConsumidorFinal) {
                    nit.value = 'CF';
                    razonSocial.value = 'Consumidor Final';
                    correoElectronico.value = '';
                } else {
                    if (nit.value === 'CF') nit.value = '';
                    if (razonSocial.value === 'Consumidor Final') razonSocial.value = '';
                }
            };

            opcionFormal.addEventListener('change', actualizarFormulario);
            opcionConsumidorFinal.addEventListener('change', actualizarFormulario);
            razonSocial.addEventListener('input', () => {
                razonSocial.value = razonSocial.value.replace(/[^A-Za-zÁÉÍÓÚÜÑáéíóúüñ ]/g, '');
            });
            form.addEventListener('submit', (event) => {
                if (form.dataset.submitting === 'true') {
                    event.preventDefault();
                    return;
                }

                form.dataset.submitting = 'true';
                guardarBtn.disabled = true;
                guardarBtn.textContent = 'Guardando...';
            });
            actualizarFormulario();
        })();
    </script>
}
