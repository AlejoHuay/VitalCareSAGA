@page
@model FrontendVCare.Pages.Proveedor.ProveedorModel
@{
    ViewData["Title"] = "Proveedores";
    var modalId = "confirmarEliminarProveedorModal";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-success">Proveedores Registrados</h2>

        <a asp-page="ProveedorCreate" class="btn-main">
            + Nuevo Proveedor
        </a>
    </div>

    <form method="get" class="mb-4">
        <div class="card-module p-3">
            <div class="input-group">
                <input type="text"
                       name="filtro"
                       class="form-control"
                       placeholder="Buscar por nombre, teléfono, correo o dirección..."
                       value="@Model.FiltroActual" />

                <button type="submit" class="btn btn-success btn-fixed">
                    Buscar
                </button>

                <a asp-page="Proveedor" class="btn btn-secondary btn-fixed">
                    Limpiar
                </a>
            </div>
        </div>
    </form>

    @if (!string.IsNullOrEmpty(Model.Mensaje))
    {
        <div class="alert alert-success shadow-sm">@Model.Mensaje</div>
    }

    @if (!string.IsNullOrEmpty(Model.MensajeError))
    {
        <div class="alert alert-danger shadow-sm">@Model.MensajeError</div>
    }

    <div class="card-module">
        <table class="table table-hover align-middle">
            <caption class="visually-hidden">Tabla de proveedores registrados con nombre, teléfono, correo, dirección y acciones disponibles.</caption>
            <thead class="table-success">
                <tr>
                    <th>Nombre</th>
                    <th>Teléfono</th>
                    <th>Correo</th>
                    <th>Dirección</th>
                    <th style="width:170px">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Proveedores.Count > 0)
                {
                    @foreach (var proveedor in Model.Proveedores)
                    {
                        <tr>
                            <td class="fw-semibold">@proveedor.Nombre</td>
                            <td>@(proveedor.Telefono ?? "-")</td>
                            <td>@(proveedor.CorreoElectronico ?? "-")</td>
                            <td>@(proveedor.Direccion ?? "-")</td>
                            <td>
                                <!-- ✅ Botón Editar corregido - Usa GET con ID en la URL -->
                                <a asp-page="ProveedorEdit" 
                                   asp-route-id="@proveedor.Id" 
                                   class="btn btn-warning btn-sm">
                                    <i class="bi bi-pencil"></i> Editar
                                </a>

                                <!-- Botón Eliminar (sin cambios) -->
                                <button type="button"
                                        class="btn btn-danger btn-sm"
                                        data-bs-toggle="modal"
                                        data-bs-target="#@modalId"
                                        data-id="@proveedor.Id"
                                        data-nombre="@proveedor.Nombre">
                                    <i class="bi bi-trash"></i> Eliminar
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">No se encontraron proveedores.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="modal fade" id="@modalId" tabindex="-1" aria-labelledby="@(modalId)Label" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header text-white bg-success">
                    <h5 class="modal-title" id="@(modalId)Label">Confirmar eliminación</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">¿Seguro que deseas eliminar este proveedor?</p>
                    <p class="fw-semibold mb-0" id="proveedorEliminarNombre"></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <form method="post" asp-page-handler="EliminarProveedor">
                        <input type="hidden" name="id" id="proveedorEliminarId" />
                        <button type="submit" class="btn btn-danger">Eliminar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const modal = document.getElementById('@modalId');
            if (!modal) return;

            modal.addEventListener('show.bs.modal', event => {
                const button = event.relatedTarget;
                modal.querySelector('#proveedorEliminarId').value = button.getAttribute('data-id');
                modal.querySelector('#proveedorEliminarNombre').textContent = button.getAttribute('data-nombre');
            });
        })();
    </script>
}