@page
@model FrontendVCare.Pages.Proveedor.ProveedorCreateModel
@{
    ViewData["Title"] = "Nuevo Proveedor";
}

<div class="medicamento-form-page">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">
                <div class="med-card shadow border-0" style="border-radius: 15px; overflow: hidden;">
                    <div class="med-card-header text-center bg-success text-white py-3">
                        <h2 class="mb-0 fw-bold text-white">Nuevo Proveedor</h2>
                        <p class="mb-0 small">Completa los datos del proveedor</p>
                    </div>

                    <div class="med-card-body p-4">
                        <form method="post" id="formProveedorCreate">
                            <div class="form-floating mb-3">
                                <input asp-for="Proveedor.Nombre"
                                       class="form-control proveedor-nombre"
                                       placeholder="Nombre"
                                       pattern="^[A-Za-z횁횋횒횙횣횥횗찼챕챠처첬체챰]+(?: [A-Za-z횁횋횒횙횣횥횗찼챕챠처첬체챰]+)*$"
                                       title="El nombre solo puede contener letras y un espacio entre palabras."
                                       autocomplete="off"
                                       required />
                                <label class="ms-2">Nombre *</label>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Proveedor.Telefono"
                                       class="form-control proveedor-telefono"
                                       placeholder="Tel챕fono"
                                       inputmode="numeric"
                                       maxlength="8"
                                       pattern="^\d{8}$"
                                       title="El tel챕fono debe tener exactamente 8 d챠gitos."
                                       autocomplete="off"
                                       required />
                                <label class="ms-2">Tel챕fono *</label>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Proveedor.CorreoElectronico"
                                       type="email"
                                       class="form-control proveedor-correo"
                                       placeholder="Correo electr처nico"
                                       autocomplete="off"
                                       required />
                                <label class="ms-2">Correo electr처nico *</label>
                            </div>

                            <div class="form-floating mb-3">
                                <textarea asp-for="Proveedor.Direccion"
                                          class="form-control proveedor-direccion"
                                          style="height: 110px"
                                          placeholder="Direcci처n"></textarea>
                                <label class="ms-2">Direcci처n</label>
                            </div>

                            @if (!string.IsNullOrEmpty(Model.Estado.MensajeError))
                            {
                                <div class="alert alert-danger">@Model.Estado.MensajeError</div>
                            }

                            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                                <a asp-page="Proveedor" class="btn btn-secondary">Volver</a>
                                <button type="submit" class="btn btn-success px-5 fw-bold shadow-sm">Crear</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
 </div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const form = document.getElementById("formProveedorCreate");

        function normalizarEspacios(valor) {
            return (valor || "").trim().replace(/\s+/g, " ");
        }

        function aplicarNormalizacion() {
            const nombre = document.querySelector(".proveedor-nombre");
            const telefono = document.querySelector(".proveedor-telefono");
            const correo = document.querySelector(".proveedor-correo");
            const direccion = document.querySelector(".proveedor-direccion");

            if (nombre) nombre.value = normalizarEspacios(nombre.value);
            if (telefono) telefono.value = telefono.value.trim();
            if (correo) correo.value = correo.value.trim();
            if (direccion) direccion.value = normalizarEspacios(direccion.value);
        }

        document.querySelectorAll(".proveedor-nombre, .proveedor-direccion").forEach(function (control) {
            control.addEventListener("blur", function () {
                control.value = normalizarEspacios(control.value);
            });
        });

        document.querySelectorAll(".proveedor-telefono, .proveedor-correo").forEach(function (control) {
            control.addEventListener("blur", function () {
                control.value = control.value.trim();
            });
        });

        if (form) {
            form.addEventListener("submit", function () {
                aplicarNormalizacion();
            });
        }
    });
</script>