@page
@model FrontendVCare.Pages.Bioquimico.BioquimicoModel
@{
    ViewData["Title"] = "Bioquímicos";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-success">Bioquímicos Registrados</h2>

        <a asp-page="BioquimicoCreate" class="btn btn-success">
            + Nuevo Bioquímico
        </a>
    </div>

    <form method="get" class="mb-4">
        <div class="card p-3 shadow-sm">
            <div class="input-group">
                <input type="text"
                       name="filtro"
                       class="form-control"
                       placeholder="Buscar por nombres, CI, email o usuario..."
                       value="@Model.Estado.FiltroActual" />

                <button type="submit" class="btn btn-success">
                    Buscar
                </button>

                <a asp-page="Bioquimico" class="btn btn-secondary">
                    Limpiar
                </a>
            </div>
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.Estado.Mensaje))
    {
        <div class="alert alert-success">@Model.Estado.Mensaje</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.Estado.MensajeError))
    {
        <div class="alert alert-danger">@Model.Estado.MensajeError</div>
    }

    <div class="card shadow-sm">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-success text-center">
                <tr>
                    <th>Nombre Completo</th>
                    <th>CI</th>
                    <th>Exp.</th>
                    <th>Teléfono</th>
                    <th>Email</th>
                    <th>Usuario</th>
                    <th>Estado</th>
                    <th style="width:170px">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Bioquimicos.Any())
                {
                    foreach (var b in Model.Bioquimicos)
                    {
                        bool activo = b.Activo == 1;

                        <tr>
                            <td>@b.Nombres @b.ApellidoPaterno @b.ApellidoMaterno</td>
                            <td>
                                @b.Ci
                            </td>
                            <td class="text-center">@b.CiExtencion</td>
                            <td>@b.Telefono</td>
                            <td>@b.Email</td>
                            <td>@b.UserName</td>
                            <td>
                                @if (activo)
                                {
                                    <span class="badge bg-success">ACTIVO</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">DE BAJA</span>
                                }
                            </td>
                            <td>
                                <div class="acciones-inline">
                                    <a asp-page="BioquimicoEdit"
                                       asp-route-id="@b.IdUsuario"
                                       class="btn btn-warning btn-sm">
                                        Editar
                                    </a>

                                    @if (activo)
                                    {
                                        <button type="button"
                                                class="btn btn-danger btn-sm btnEliminar"
                                                data-id="@b.IdUsuario"
                                                data-nombre="@b.Nombres @b.ApellidoPaterno @b.ApellidoMaterno"
                                                data-bs-toggle="modal"
                                                data-bs-target="#modalEliminarBioquimico">
                                            Baja
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center py-4 text-muted">
                            No se encontraron bioquímicos.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalEliminarBioquimico" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Confirmar baja</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p>¿Está seguro de dar de baja a este bioquímico?</p>
                <p class="fw-bold" id="nombreBioquimicoEliminar"></p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancelar
                </button>

                <form method="post" asp-page-handler="DarBaja">
                    <input type="hidden" id="idBioquimicoEliminar" name="id" />
                    <input type="hidden" name="filtro" value="@Model.Estado.FiltroActual" />
                    <button type="submit" class="btn btn-danger">
                        Confirmar Baja
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll(".btnEliminar").forEach(btn => {
            btn.addEventListener("click", function () {
                document.getElementById("idBioquimicoEliminar").value = this.dataset.id;
                document.getElementById("nombreBioquimicoEliminar").textContent = this.dataset.nombre;
            });
        });
    </script>
}
