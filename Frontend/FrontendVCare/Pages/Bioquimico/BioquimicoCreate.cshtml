@page
@model FrontendVCare.Pages.Bioquimico.BioquimicoCreateModel
@{
    ViewData["Title"] = "Nuevo Bioquímico";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow border-0">
                <div class="card-header bg-success text-white text-center">
                    <h2 class="mb-0">Nuevo Bioquímico</h2>
                    <p class="mb-0 small">Las credenciales se generarán y enviarán automáticamente</p>
                </div>

                <div class="card-body p-4">
                    <form method="post">

                        <div class="form-floating mb-3">
                            <input asp-for="Registro.Nombres" class="form-control" placeholder="Nombres" />
                            <label>Nombres</label>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Registro.ApellidoPaterno" class="form-control" placeholder="Apellido paterno" />
                                    <label>Primer apellido</label>
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Registro.ApellidoMaterno" class="form-control" placeholder="Apellido materno" />
                                    <label>Segundo apellido (opcional)</label>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-5 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Registro.Ci" class="form-control" placeholder="CI" maxlength="8" />
                                    <label>Carnet de identidad</label>
                                    <small class="text-muted">CI: Ej. 12345678</small>
                                </div>
                            </div>

                            <div class="col-md-3 mb-3">
                                <div class="form-floating">
                                    <input asp-for="CiComplemento" class="form-control" placeholder="Complemento" maxlength="2" />
                                    <label>Complemento</label>
                                    <small class="text-muted">Opcional. Ej. 1A</small>
                                </div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <div class="form-floating">
                                    <select asp-for="Registro.CiExtencion" class="form-select">
                                        <option value="">Seleccione</option>
                                        <option value="BE">Beni</option>
                                        <option value="CB">Cochabamba</option>
                                        <option value="CH">Chuquisaca</option>
                                        <option value="LP">La Paz</option>
                                        <option value="OR">Oruro</option>
                                        <option value="PD">Pando</option>
                                        <option value="PT">Potosí</option>
                                        <option value="SC">Santa Cruz</option>
                                        <option value="TJ">Tarija</option>
                                    </select>
                                    <label>Expedido</label>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Registro.Telefono" class="form-control" placeholder="Teléfono" maxlength="8" />
                            <label>Teléfono</label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Registro.Email" type="email" class="form-control" placeholder="Email" />
                            <label>Correo electrónico</label>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.Estado.MensajeError))
                        {
                            <div class="alert alert-danger">
                                @Model.Estado.MensajeError
                            </div>
                        }
                        else if (!ViewContext.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                @{
                                    string[] ordenCampos =
                                    [
                                        "Registro.Nombres",
                                        "Registro.ApellidoPaterno",
                                        "Registro.ApellidoMaterno",
                                        "Registro.Ci",
                                        "CiComplemento",
                                        "Registro.CiExtencion",
                                        "Registro.Telefono",
                                        "Registro.Email"
                                    ];

                                    string primerError = "Error de validación.";

                                    foreach (string campo in ordenCampos)
                                    {
                                        if (ViewContext.ModelState.TryGetValue(campo, out var entry)
                                            && entry.Errors.Count > 0)
                                        {
                                            primerError = entry.Errors.First().ErrorMessage;
                                            break;
                                        }
                                    }

                                    @primerError
                                }
                            </div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-page="Bioquimico" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-success">
                                Guardar Registro
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
