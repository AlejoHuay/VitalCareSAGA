@page
@model FrontendVCare.Pages.Bioquimico.BioquimicoEditModel
@{
    ViewData["Title"] = "Actualizar Bioquímico";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9 col-md-11">
            <div class="card shadow border-0">
                <div class="card-header bg-success text-white text-center">
                    <h2 class="mb-0">Actualizar Bioquímico</h2>
                    <p class="mb-0 small">Edita los datos del profesional</p>
                </div>

                <div class="card-body p-4">
                    <form method="post">
                        <input type="hidden" asp-for="Input.IdUsuario" />
                        <input type="hidden" asp-for="Input.Role" />
                        <input type="hidden" asp-for="Input.UserName" />
                        <input type="hidden" asp-for="Input.MustChangePassword" />
                        <input type="hidden" asp-for="Input.Activo" />

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Nombres" class="form-control" placeholder="Nombres" />
                            <label>Nombres</label>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.ApellidoPaterno" class="form-control" placeholder="Apellido paterno" />
                                    <label>Primer Apellido</label>
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.ApellidoMaterno" class="form-control" placeholder="Apellido materno" />
                                    <label>Segundo Apellido (opcional)</label>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-5 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.Ci" class="form-control" placeholder="CI" maxlength="8" />
                                    <label>Carnet de Identidad</label>
                                    <small class="text-muted">CI: Ej. 12345678</small>
                                </div>
                            </div>

                            <div class="col-md-3 mb-3">
                                <div class="form-floating">
                                    <input asp-for="CiComplemento" class="form-control" placeholder="Complemento" maxlength="2" />
                                    <label>Complemento</label>
                                    <small class="text-muted">Opcional. Ej. 1A</small>
                                </div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <div class="form-floating">
                                    <select asp-for="Input.CiExtencion" class="form-select">
                                        <option value="">Seleccione</option>
                                        <option value="BE">Beni</option>
                                        <option value="CB">Cochabamba</option>
                                        <option value="CH">Chuquisaca</option>
                                        <option value="LP">La Paz</option>
                                        <option value="OR">Oruro</option>
                                        <option value="PD">Pando</option>
                                        <option value="PT">Potosí</option>
                                        <option value="SC">Santa Cruz</option>
                                        <option value="TJ">Tarija</option>
                                    </select>
                                    <label>Expedido en</label>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Telefono" class="form-control" placeholder="Teléfono" />
                            <label>Teléfono</label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" type="email" class="form-control" placeholder="Email" />
                            <label>Correo Electrónico</label>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label class="form-label fw-bold small text-muted">Usuario del Sistema</label>
                                <div class="form-control bg-light">@Model.Input.UserName</div>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.Estado.MensajeError))
                        {
                            <div class="alert alert-danger">@Model.Estado.MensajeError</div>
                        }
                        else if (!ViewContext.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                @{
                                    string[] ordenCampos =
                                    [
                                        "Input.Nombres",
                                        "Input.ApellidoPaterno",
                                        "Input.ApellidoMaterno",
                                        "Input.Ci",
                                        "CiComplemento",
                                        "Input.CiExtencion",
                                        "Input.Telefono",
                                        "Input.Email"
                                    ];

                                    string primerError = "Error de validación.";

                                    foreach (string campo in ordenCampos)
                                    {
                                        if (ViewContext.ModelState.TryGetValue(campo, out var entry)
                                            && entry.Errors.Count > 0)
                                        {
                                            primerError = entry.Errors.First().ErrorMessage;
                                            break;
                                        }
                                    }

                                    @primerError
                                }
                            </div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-page="Bioquimico" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-success">
                                Actualizar Registro
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>