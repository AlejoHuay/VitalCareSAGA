@page
@model FrontendVCare.Pages.Medicamento.ActualizarMedicamentoModel

<div class="container py-5 medicamento-form-page">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="med-card shadow border-0" style="border-radius: 15px; overflow: hidden;">
                <div class="med-card-header text-center bg-success text-white py-3">
                    <h2 class="mb-0 fw-bold text-white">Actualizar Medicamento</h2>
                    <p class="mb-0 small">Modifica los datos del medicamento</p>
                </div>

                <div class="med-card-body p-4">
                    @if (Model.Medicamento != null)
                    {
                        <form method="post" asp-page-handler="ActualizarMedicamento">
                            <input type="hidden" asp-for="Id" />

                            <div class="form-floating mb-3">
                                <input asp-for="Nombre" class="form-control" placeholder="Nombre" pattern="[A-Za-zÁÉÍÓÚÜÑáéíóúüñ0-9 ]+" title="No se permiten signos ni caracteres especiales." required />
                                <label class="ms-2">Nombre</label>
                            </div>

                            <div class="form-floating mb-3">
                                <select asp-for="Presentacion" class="form-select" required>
                                    <option value="" disabled>Seleccione</option>
                                    <option value="Cápsulas" selected="@(Model.Presentacion == "Cápsulas" ? "selected" : null)">Cápsulas</option>
                                    <option value="Crema" selected="@(Model.Presentacion == "Crema" ? "selected" : null)">Crema</option>
                                    <option value="Gotas" selected="@(Model.Presentacion == "Gotas" ? "selected" : null)">Gotas</option>
                                    <option value="Inyectable" selected="@(Model.Presentacion == "Inyectable" ? "selected" : null)">Inyectable</option>
                                    <option value="Jarabe" selected="@(Model.Presentacion == "Jarabe" ? "selected" : null)">Jarabe</option>
                                    <option value="Polvo" selected="@(Model.Presentacion == "Polvo" ? "selected" : null)">Polvo</option>
                                    <option value="Pomada" selected="@(Model.Presentacion == "Pomada" ? "selected" : null)">Pomada</option>
                                    <option value="Suspensión" selected="@(Model.Presentacion == "Suspensión" ? "selected" : null)">Suspensión</option>
                                    <option value="Tabletas" selected="@(Model.Presentacion == "Tabletas" ? "selected" : null)">Tabletas</option>
                                </select>
                                <label class="ms-2">Presentación</label>
                            </div>

                            <div class="form-floating mb-3">
                                <select asp-for="IdClasificacion" class="form-select" required>
                                    <option value="" disabled>Seleccione</option>
                                    @foreach (var clasificacion in Model.Clasificaciones)
                                    {
                                        <option value="@clasificacion.Id" selected="@(clasificacion.Id == Model.IdClasificacion ? "selected" : null)">@clasificacion.Nombre</option>
                                    }
                                </select>
                                <label class="ms-2">Clasificación</label>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Concentracion" class="form-control" placeholder="Concentración" required />
                                <label class="ms-2">Concentración</label>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Precio" class="form-control" placeholder="Precio" type="number" step="0.01" min="0" required />
                                <label class="ms-2">Precio</label>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Stock" class="form-control" placeholder="Stock" type="number" min="0" required />
                                <label class="ms-2">Stock</label>
                            </div>

                            @if (!string.IsNullOrEmpty(Model.MensajeError))
                            {
                                <div class="alert alert-danger">@Model.MensajeError</div>
                            }

                            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                                <a asp-page="/Medicamento/Medicamento" class="btn btn-secondary">Volver</a>
                                <button type="submit" class="btn btn-success px-5 fw-bold shadow-sm">Actualizar</button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-warning">No se encontraron datos del medicamento.</div>
                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <a asp-page="/Medicamento/Medicamento" class="btn btn-secondary">Volver</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
