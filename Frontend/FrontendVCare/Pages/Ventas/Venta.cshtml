@page
@model FrontendVCare.Pages.Ventas.VentaModel

@{
    ViewData["Title"] = "Ventas";
}

<div class="container mt-5 no-card-hover">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-success">Ventas</h2>
            <p class="text-muted mb-0">Consulta y administra el historial de ventas</p>
        </div>
        <a asp-page="/Ventas/NuevaVenta" class="btn btn-success">+ Agregar venta</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.Mensaje))
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            @Model.Mensaje
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.MensajeError))
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            @Model.MensajeError
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="get" class="mb-4">
        <div class="card-module p-3">
            <div class="input-group">
                <input type="text"
                       name="filtro"
                       class="form-control"
                       placeholder="Buscar por cliente o metodo de pago"
                       value="@Model.Filtro" />
                <button type="submit" class="btn btn-success btn-fixed">Buscar</button>
                <a asp-page="/Ventas/Venta" class="btn btn-secondary btn-fixed">Limpiar</a>
            </div>
        </div>
    </form>

    <div class="card shadow-sm">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-success">
                <tr>
                    <th>Fecha</th>
                    <th>Cliente</th>
                    <th>Metodo de pago</th>
                    <th>Total (Bs)</th>
                    <th style="width:170px">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Ventas.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No hay ventas registradas.</td>
                    </tr>
                }
                @foreach (var venta in Model.Ventas)
                {
                    string cliente = !string.IsNullOrWhiteSpace(venta.RazonSocial)
                        ? venta.RazonSocial
                        : venta.Cliente;

                    <tr>
                        <td>@(ObtenerFechaVenta(venta).ToString("dd/MM/yyyy HH:mm"))</td>
                        <td class="fw-semibold">@cliente</td>
                        <td>@venta.MetodoPago</td>
                        <td class="text-success fw-bold">@venta.Total.ToString("N2")</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-page="/Ventas/VerVenta" asp-route-id="@venta.Id" class="btn btn-success btn-sm">Ver</a>
                                <button type="button"
                                        class="btn btn-danger btn-sm btn-anular"
                                        data-id="@venta.Id"
                                        data-cliente="@cliente"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalAnularVenta">
                                    Anular
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.DescargarComprobanteId.HasValue && Model.DescargarComprobanteId.Value > 0)
{
    <iframe name="comprobanteDescargaFrame" class="d-none"></iframe>
    <a asp-page="/Ventas/VerVenta"
       asp-page-handler="DescargarComprobante"
       asp-route-id="@Model.DescargarComprobanteId.Value"
       target="comprobanteDescargaFrame"
       id="descargaComprobanteAutomatica"
       class="d-none">
        Descargar comprobante
    </a>
}

<div class="modal fade" id="modalAnularVenta" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Confirmar anulacion</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-1">Esta accion anulara la venta seleccionada.</p>
                <p class="fw-bold mb-0" id="clienteVentaAnular"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form method="post" asp-page-handler="Anular">
                    <input type="hidden" id="idVentaAnular" name="id" />
                    <button type="submit" class="btn btn-danger">Anular venta</button>
                </form>
            </div>
        </div>
    </div>
</div>

@functions {
    private static DateTime ObtenerFechaVenta(FrontendVCare.Dto.Ventas.VentaDto venta)
    {
        return venta.FechaHora != default ? venta.FechaHora : venta.Fecha;
    }
}

<script>
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".btn-anular").forEach((button) => {
            button.addEventListener("click", function () {
                document.getElementById("idVentaAnular").value = this.dataset.id || "";
                document.getElementById("clienteVentaAnular").textContent =
                    "Cliente: " + (this.dataset.cliente || "Sin nombre");
            });
        });

        const descargaAutomatica = document.getElementById("descargaComprobanteAutomatica");
        if (descargaAutomatica) {
            window.setTimeout(() => descargaAutomatica.click(), 800);

            const url = new URL(window.location.href);
            url.searchParams.delete("descargarComprobanteId");
            window.history.replaceState({}, document.title, url.toString());
        }
    });
</script>
