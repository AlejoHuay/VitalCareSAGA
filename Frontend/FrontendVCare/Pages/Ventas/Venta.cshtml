@page
@model FrontendVCare.Pages.Ventas.VentaModel

@{
    ViewData["Title"] = "Ventas";
}

<div class="container mt-5 no-card-hover">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-success">Ventas</h2>
            <p class="text-muted mb-0">Consulta y administra el historial de ventas</p>
        </div>
        <a asp-page="/Ventas/NuevaVenta" class="btn btn-success">+ Agregar venta</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.Mensaje))
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            @Model.Mensaje
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.MensajeError))
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            @Model.MensajeError
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="get" class="mb-4">
        <div class="card-module p-3">
            <div class="input-group">
                <input type="text"
                       name="filtro"
                       class="form-control"
                       placeholder="Buscar por cliente, usuario o estado" />
                <button type="submit" class="btn btn-success btn-fixed">Buscar</button>
                <a asp-page="/Ventas/Venta" class="btn btn-secondary btn-fixed">Limpiar</a>
            </div>
        </div>
    </form>

    <div class="card shadow-sm">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-success">
                <tr>
                    <th>Fecha</th>
                    <th>Cliente</th>
                    <th>Usuario</th>
                    <th>Total (Bs)</th>
                    <th>Estado</th>
                    <th style="width:120px">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Ventas.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No hay ventas registradas.</td>
                    </tr>
                }
                @foreach (var venta in Model.Ventas)
                {
                    <tr>
                        <td>@venta.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="fw-semibold">@venta.Cliente</td>
                        <td>@venta.Usuario</td>
                        <td>@venta.Total.ToString("N2")</td>
                        <td>@venta.Estado</td>
                        <td>
                            <form method="post" asp-page-handler="Anular" asp-route-id="@venta.Id">
                                <button type="submit" class="btn btn-danger btn-sm">Anular</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
