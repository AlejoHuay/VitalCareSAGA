@page
@model FrontendVCare.Pages.Ventas.ReporteVentasPorRolModel

@{
    ViewData["Title"] = "Reporte por Rol";
}

<div class="container mt-5 no-card-hover sales-report-shell">
    <div class="report-header mb-4">
        <div>
            <h2 class="fw-bold text-success">Reporte de ventas por rol</h2>
            <p class="text-muted mb-1">Resumen de ventas agrupadas por rol de usuario</p>
            <span class="report-period">@Model.PeriodoTexto</span>
        </div>
        <div class="report-actions">
            <a asp-page-handler="DescargarPdf"
               asp-route-desde="@Model.Desde?.ToString("yyyy-MM-dd")"
               asp-route-hasta="@Model.Hasta?.ToString("yyyy-MM-dd")"
               class="btn btn-success">
                <i class="bi bi-file-earmark-pdf"></i> Descargar PDF
            </a>
            <a asp-page-handler="DescargarExcel"
               asp-route-desde="@Model.Desde?.ToString("yyyy-MM-dd")"
               asp-route-hasta="@Model.Hasta?.ToString("yyyy-MM-dd")"
               class="btn btn-outline-success">
                <i class="bi bi-file-earmark-spreadsheet"></i> Descargar Excel
            </a>
            <a asp-page="/Ventas/Venta" class="btn btn-outline-secondary">Volver a ventas</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.MensajeError))
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            @Model.MensajeError
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="get" class="mb-4 report-filter">
        <div class="card-module p-3">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label asp-for="Desde" class="form-label">Desde</label>
                    <input asp-for="Desde" type="date" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Hasta" class="form-label">Hasta</label>
                    <input asp-for="Hasta" type="date" class="form-control" />
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-success btn-fixed">Filtrar</button>
                    <a asp-page="/Ventas/ReporteVentasPorRol" class="btn btn-secondary btn-fixed">Limpiar</a>
                </div>
            </div>
        </div>
    </form>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm report-summary-card">
                <div class="card-body">
                    <p class="text-muted mb-1">Cantidad de ventas</p>
                    <h3 class="fw-bold mb-0">@Model.TotalVentas</h3>
                    <span class="summary-hint">Operaciones confirmadas</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm report-summary-card">
                <div class="card-body">
                    <p class="text-muted mb-1">Total vendido</p>
                    <h3 class="fw-bold mb-0">Bs @Model.TotalRecaudado.ToString("N2")</h3>
                    <span class="summary-hint">Importe acumulado</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm report-summary-card">
                <div class="card-body">
                    <p class="text-muted mb-1">Rol con mas ventas</p>
                    <h3 class="fw-bold mb-0 summary-role">@((Model.RolConMasVentas?.Rol) ?? "-")</h3>
                    <span class="summary-hint">@((Model.RolConMasVentas?.CantidadVentas.ToString()) ?? "0") ventas</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm report-summary-card">
                <div class="card-body">
                    <p class="text-muted mb-1">Mayor recaudacion</p>
                    <h3 class="fw-bold mb-0 summary-role">@((Model.RolConMasRecaudacion?.Rol) ?? "-")</h3>
                    <span class="summary-hint">Bs @((Model.RolConMasRecaudacion?.TotalRecaudado.ToString("N2")) ?? "0.00")</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4 report-visual-card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <span class="section-kicker">Visualizacion</span>
                    <h4 class="fw-bold mb-1">Ventas por rol</h4>
                    <p class="text-muted mb-0">Comparacion proporcional segun el total vendido.</p>
                </div>
                @if (Model.TieneDatos)
                {
                    <span class="badge text-bg-success">Datos reales</span>
                }
            </div>

            @if (!Model.TieneDatos)
            {
                <div class="empty-detail">No hay datos para graficar en el periodo seleccionado.</div>
            }
            else
            {
                <div class="report-bars">
                    @foreach (var item in Model.Reporte)
                    {
                        var porcentaje = Model.MaximoRecaudado > 0
                            ? Math.Max(6, (int)Math.Round(item.TotalRecaudado / Model.MaximoRecaudado * 100))
                            : 0;

                        <div class="report-bar-row">
                            <div class="report-bar-label">
                                <strong>@item.Rol</strong>
                                <span>@item.CantidadVentas ventas</span>
                            </div>
                            <div class="report-bar-track">
                                <div class="report-bar-fill" style="width:@porcentaje%"></div>
                            </div>
                            <div class="report-bar-value">Bs @item.TotalRecaudado.ToString("N2")</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="card shadow-sm report-table-card">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-success">
                <tr>
                    <th>Rol</th>
                    <th>Cantidad de ventas</th>
                    <th>Total vendido (Bs)</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.TieneDatos)
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">No hay datos para mostrar.</td>
                    </tr>
                }
                @for (int i = 0; i < Model.Reporte.Count; i++)
                {
                    var item = Model.Reporte[i];
                    var collapseId = $"usuariosRol{i}";

                    <tr>
                        <td class="fw-semibold">
                            <button class="btn btn-link report-role-toggle p-0"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#@collapseId"
                                    aria-expanded="false"
                                    aria-controls="@collapseId">
                                <i class="bi bi-chevron-down"></i>
                                @item.Rol
                            </button>
                            <span class="report-user-count">@item.Usuarios.Count usuario(s)</span>
                        </td>
                        <td>@item.CantidadVentas</td>
                        <td>@item.TotalRecaudado.ToString("N2")</td>
                    </tr>
                    <tr class="report-user-row">
                        <td colspan="3" class="p-0">
                            <div class="collapse" id="@collapseId">
                                <div class="report-user-panel">
                                    @if (item.Usuarios.Count == 0)
                                    {
                                        <div class="text-muted">No hay usuarios para este rol.</div>
                                    }
                                    else
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-sm mb-0 align-middle report-user-table">
                                                <thead>
                                                    <tr>
                                                        <th>Usuario</th>
                                                        <th>Cantidad de ventas</th>
                                                        <th>Total vendido (Bs)</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var usuario in item.Usuarios)
                                                    {
                                                        <tr>
                                                            <td>@usuario.NombreUsuario</td>
                                                            <td>@usuario.CantidadVentas</td>
                                                            <td class="fw-semibold text-success">@usuario.TotalRecaudado.ToString("N2")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                                <tfoot>
                                                    <tr>
                                                        <td class="fw-bold">Total @item.Rol</td>
                                                        <td class="fw-bold">@item.CantidadVentas</td>
                                                        <td class="fw-bold text-success">@item.TotalRecaudado.ToString("N2")</td>
                                                    </tr>
                                                </tfoot>
                                            </table>
                                        </div>
                                    }
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
            @if (Model.TieneDatos)
            {
                <tfoot>
                    <tr>
                        <td class="fw-bold">TOTAL</td>
                        <td class="fw-bold">@Model.TotalVentas</td>
                        <td class="fw-bold text-success">@Model.TotalRecaudado.ToString("N2")</td>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
</div>
