@page
@model FrontendVCare.Pages.Ventas.NuevaVentaModel

@{
    ViewData["Title"] = "Nueva venta";
}

<div class="container mt-5 no-card-hover">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-success">Nueva venta</h2>
            <p class="text-muted mb-0">Selecciona un cliente y los medicamentos de la venta</p>
        </div>
        <a asp-page="/Ventas/Venta" class="btn btn-outline-secondary">Volver a ventas</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.MensajeError))
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            @Model.MensajeError
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-success text-white fw-semibold">
            Datos de la venta
        </div>
        <div class="card-body">
            <form method="post">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-md-5">
                        <label asp-for="Venta.IdCliente" class="form-label">Cliente</label>
                        <div class="input-group">
                            <select asp-for="Venta.IdCliente" class="form-select" required>
                                <option value="">Seleccionar cliente</option>
                                @foreach (var cliente in Model.Clientes)
                                {
                                    <option value="@cliente.IdCliente">@cliente.RazonSocial (@cliente.Nit)</option>
                                }
                            </select>
                            <button type="button" class="btn btn-outline-success" data-bs-toggle="modal" data-bs-target="#modalNuevoCliente">
                                + Nuevo cliente
                            </button>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Venta.MetodoPago" class="form-label">Método de pago</label>
                        <select asp-for="Venta.MetodoPago" class="form-select" required>
                            <option value="">Seleccionar método</option>
                            @foreach (var metodo in Model.MetodosPago)
                            {
                                <option value="@metodo">@metodo</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="table-responsive mt-4">
                    <table class="table align-middle" id="detalleVenta">
                        <thead class="table-success">
                            <tr>
                                <th>Medicamento</th>
                                <th style="width:140px">Cantidad</th>
                                <th style="width:160px">Precio (Bs)</th>
                                <th style="width:130px">Subtotal</th>
                                <th style="width:80px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>
                                    <select name="Venta.Detalles[0].IdMedicamento" class="form-select medicamento-select" required>
                                        <option value="">Seleccionar medicamento</option>
                                        @foreach (var medicamento in Model.Medicamentos)
                                        {
                                            <option value="@medicamento.Id" data-precio="@medicamento.Precio.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                                @medicamento.Nombre - @medicamento.Presentacion
                                            </option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    <input name="Venta.Detalles[0].Cantidad" type="number" min="1" value="1" class="form-control cantidad-input" required />
                                </td>
                                <td>
                                    <input name="Venta.Detalles[0].PrecioUnitario" type="hidden" class="precio-hidden" />
                                    <span class="precio-text">0.00</span>
                                </td>
                                <td class="subtotal-cell fw-semibold">0.00</td>
                                <td>
                                    <button type="button" class="btn btn-outline-danger btn-sm quitar-detalle">Quitar</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center">
                    <button type="button" class="btn btn-outline-success" id="agregarDetalle">+ Agregar medicamento</button>
                    <div class="d-flex align-items-center gap-3">
                        <span class="fs-5 fw-bold">Total: Bs <span id="totalVenta">0.00</span></span>
                        <a asp-page="/Ventas/Venta" class="btn btn-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-primary">Registrar venta</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalNuevoCliente" tabindex="-1" aria-labelledby="modalNuevoClienteLabel" aria-hidden="true" data-id-usuario="@Model.IdUsuarioActual">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="modalNuevoClienteLabel">Nuevo cliente</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <form id="formNuevoCliente">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tipo de cliente</label>
                        <div class="d-flex gap-3">
                            <label class="form-check-label">
                                <input type="radio" name="tipoCliente" value="false" class="form-check-input me-2" checked> Cliente con datos fiscales
                            </label>
                            <label class="form-check-label">
                                <input type="radio" name="tipoCliente" value="true" class="form-check-input me-2"> Consumidor Final
                            </label>
                        </div>
                    </div>

                    <div id="modalContenedorClienteFiscal">
                        <div class="form-floating mb-3">
                            <input id="nuevoClienteNit" class="form-control" placeholder="NIT" inputmode="numeric" pattern="[0-9]*" title="El NIT solo acepta números." required />
                            <label for="nuevoClienteNit">NIT / CI</label>
                        </div>

                        <div class="form-floating mb-3">
                            <input id="nuevoClienteRazonSocial" class="form-control" placeholder="Razón Social" minlength="3" maxlength="45" pattern="[\p{L} ]+" title="Solo se permiten letras y espacios." required />
                            <label for="nuevoClienteRazonSocial">Razón Social / Nombre Completo</label>
                        </div>

                        <div class="form-floating mb-3">
                            <input id="nuevoClienteCorreo" type="email" class="form-control" placeholder="Correo electrónico opcional" maxlength="45" />
                            <label for="nuevoClienteCorreo">Correo electrónico (opcional)</label>
                        </div>
                    </div>

                    <div id="modalBloqueConsumidorFinal" class="alert alert-success border-0 mb-3" style="display:none;">
                        Se registrará el cliente como <strong>Consumidor Final</strong>.
                    </div>

                    <div id="clienteError" class="alert alert-danger d-none" role="alert"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success" id="guardarNuevoClienteBtn">Guardar cliente</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const tabla = document.querySelector("#detalleVenta tbody");
        const agregar = document.getElementById("agregarDetalle");
        const total = document.getElementById("totalVenta");

        function renumerar() {
            tabla.querySelectorAll("tr").forEach((fila, index) => {
                fila.querySelectorAll("select, input").forEach((control) => {
                    control.name = control.name.replace(/Venta\.Detalles\[\d+\]/, `Venta.Detalles[${index}]`);
                });
            });
        }

        function recalcular() {
            let suma = 0;
            tabla.querySelectorAll("tr").forEach((fila) => {
                const cantidad = Number(fila.querySelector(".cantidad-input").value || 0);
                const precio = Number(fila.querySelector(".precio-hidden").value || 0);
                const subtotal = cantidad * precio;
                fila.querySelector(".subtotal-cell").textContent = subtotal.toFixed(2);
                suma += subtotal;
            });
            total.textContent = suma.toFixed(2);
        }

        function inicializarFila(fila) {
            const select = fila.querySelector('.medicamento-select');
            const ph = fila.querySelector('.precio-hidden');
            const pt = fila.querySelector('.precio-text');
            const precioRaw = select?.selectedOptions[0]?.dataset.precio;
            const precioNum = precioRaw ? parseFloat(precioRaw.toString().replace(',', '.')) : 0;
            if (ph) ph.value = precioNum ? precioNum.toFixed(2) : '';
            if (pt) pt.textContent = precioNum ? precioNum.toFixed(2) : '0.00';
        }

        tabla.addEventListener("change", function (event) {
            if (event.target.classList.contains("medicamento-select")) {
                const precioRaw = event.target.selectedOptions[0]?.dataset.precio || "0";
                const precioNum = parseFloat(precioRaw.toString().replace(',', '.')) || 0;
                const fila = event.target.closest("tr");
                const ph = fila.querySelector(".precio-hidden");
                const pt = fila.querySelector(".precio-text");
                if (ph) ph.value = precioNum ? precioNum.toFixed(2) : "";
                if (pt) pt.textContent = precioNum ? precioNum.toFixed(2) : '0.00';
                recalcular();
            }
        });

        tabla.addEventListener("input", recalcular);

        tabla.addEventListener("click", function (event) {
            if (!event.target.classList.contains("quitar-detalle")) {
                return;
            }

            if (tabla.querySelectorAll("tr").length > 1) {
                event.target.closest("tr").remove();
                renumerar();
                recalcular();
            }
        });

        agregar.addEventListener("click", function () {
            const nuevaFila = tabla.querySelector("tr").cloneNode(true);
            nuevaFila.querySelectorAll("select, input").forEach((control) => {
                control.value = control.classList.contains("cantidad-input") ? "1" : "";
            });
            // Asegurar que el texto de precio y subtotal queden en 0.00
            const pt = nuevaFila.querySelector(".precio-text");
            const ph = nuevaFila.querySelector(".precio-hidden");
            if (ph) ph.value = "";
            if (pt) pt.textContent = "0.00";
            nuevaFila.querySelector(".subtotal-cell").textContent = "0.00";
            tabla.appendChild(nuevaFila);
            renumerar();
            inicializarFila(nuevaFila);
        });

        const modal = document.getElementById('modalNuevoCliente');
        const clienteFiscalContainer = document.getElementById('modalContenedorClienteFiscal');
        const consumidorFinalInfo = document.getElementById('modalBloqueConsumidorFinal');
        const clienteError = document.getElementById('clienteError');
        const guardarClienteBtn = document.getElementById('guardarNuevoClienteBtn');
        const clienteNit = document.getElementById('nuevoClienteNit');
        const clienteRazonSocial = document.getElementById('nuevoClienteRazonSocial');
        const clienteCorreo = document.getElementById('nuevoClienteCorreo');
        const clienteTipoRadios = document.querySelectorAll('input[name="tipoCliente"]');
        const clienteSelect = document.getElementById('Venta_IdCliente');
        const idUsuarioActual = Number(modal?.dataset.idUsuario || 0);
        const antiforgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

        const actualizarModalTipoCliente = () => {
            const esConsumidorFinal = document.querySelector('input[name="tipoCliente"]:checked')?.value === 'true';
            consumidorFinalInfo.style.display = esConsumidorFinal ? '' : 'none';
            clienteFiscalContainer.style.display = esConsumidorFinal ? 'none' : '';
            clienteNit.required = !esConsumidorFinal;
            clienteRazonSocial.required = !esConsumidorFinal;

            if (esConsumidorFinal) {
                clienteNit.value = 'CF';
                clienteRazonSocial.value = 'Consumidor Final';
                clienteCorreo.value = '';
            } else {
                if (clienteNit.value === 'CF') clienteNit.value = '';
                if (clienteRazonSocial.value === 'Consumidor Final') clienteRazonSocial.value = '';
            }
        };

        clienteTipoRadios.forEach(radio => radio.addEventListener('change', actualizarModalTipoCliente));
        actualizarModalTipoCliente();

        guardarClienteBtn.addEventListener('click', async () => {
            clienteError.classList.add('d-none');
            clienteError.textContent = '';

            const esConsumidorFinal = document.querySelector('input[name="tipoCliente"]:checked')?.value === 'true';
            const nit = clienteNit.value.trim();
            const razonSocial = clienteRazonSocial.value.trim();
            const correo = clienteCorreo.value.trim();

            if (!esConsumidorFinal) {
                if (!nit) {
                    clienteError.textContent = 'El NIT no puede estar vacío.';
                    clienteError.classList.remove('d-none');
                    return;
                }

                if (!/^\d+$/.test(nit)) {
                    clienteError.textContent = 'El NIT solo acepta números.';
                    clienteError.classList.remove('d-none');
                    return;
                }

                if (!razonSocial) {
                    clienteError.textContent = 'La razón social no puede estar vacía.';
                    clienteError.classList.remove('d-none');
                    return;
                }
            }

            if (!idUsuarioActual) {
                clienteError.textContent = 'No se pudo obtener la sesión del usuario. Recarga la página.';
                clienteError.classList.remove('d-none');
                return;
            }

            guardarClienteBtn.disabled = true;
            guardarClienteBtn.textContent = 'Guardando...';

            try {
                const response = await fetch('?handler=CrearCliente', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': antiforgeryToken
                    },
                    body: JSON.stringify({
                        idUsuario: idUsuarioActual,
                        esConsumidorFinal: esConsumidorFinal,
                        nit: nit,
                        razonSocial: razonSocial,
                        correoElectronico: correo
                    })
                });

                const contenido = await response.json();
                if (!response.ok) {
                    clienteError.textContent = contenido.mensaje || 'No se pudo crear el cliente.';
                    clienteError.classList.remove('d-none');
                    return;
                }

                const nuevoClienteId = contenido.data?.idCliente || contenido.idCliente || 0;
                const nuevaRazonSocial = contenido.data?.razonSocial || razonSocial;
                const nuevoNit = contenido.data?.nit || nit;

                if (!nuevoClienteId) {
                    clienteError.textContent = contenido.mensaje || 'Cliente creado, pero no se devolvió el ID.';
                    clienteError.classList.remove('d-none');
                    return;
                }

                const nuevaOpcion = document.createElement('option');
                nuevaOpcion.value = nuevoClienteId;
                nuevaOpcion.textContent = `${nuevaRazonSocial} (${nuevoNit})`;
                nuevaOpcion.selected = true;
                clienteSelect.appendChild(nuevaOpcion);

                const bsModal = bootstrap.Modal.getInstance(modal) || new bootstrap.Modal(modal);
                bsModal.hide();
                clienteNit.value = '';
                clienteRazonSocial.value = '';
                clienteCorreo.value = '';
                clienteTipoRadios[0].checked = true;
                actualizarModalTipoCliente();
            } catch (error) {
                clienteError.textContent = 'No se pudo crear el cliente. Verifica tu conexión.';
                clienteError.classList.remove('d-none');
            } finally {
                guardarClienteBtn.disabled = false;
                guardarClienteBtn.textContent = 'Guardar cliente';
            }
        });

        // Inicializar filas existentes para evitar NaN
        tabla.querySelectorAll('tr').forEach(f => inicializarFila(f));
        recalcular();
    });
</script>
