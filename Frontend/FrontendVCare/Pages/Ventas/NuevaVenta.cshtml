@page
@using System.Text.Json
@model FrontendVCare.Pages.Ventas.NuevaVentaModel

@{
    ViewData["Title"] = "Nueva venta";

    var clientesJson = JsonSerializer.Serialize(Model.Clientes.Select(cliente => new
    {
        id = cliente.IdCliente,
        nit = cliente.Nit,
        razonSocial = cliente.RazonSocial,
        esConsumidorFinal = cliente.EsConsumidorFinal
    }));

    var medicamentosJson = JsonSerializer.Serialize(Model.Medicamentos.Select(medicamento => new
    {
        id = medicamento.Id,
        nombre = medicamento.Nombre,
        presentacion = medicamento.Presentacion,
        precio = medicamento.Precio,
        stock = medicamento.Stock
    }));
}

<div class="container mt-5 mb-5 no-card-hover">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-success">Nueva venta</h2>
            <p class="text-muted mb-0">Registra el cliente, los medicamentos y el pago de la venta</p>
        </div>
        <a asp-page="/Ventas/Venta" class="btn btn-outline-secondary">Volver a ventas</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.MensajeError))
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            @Model.MensajeError
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="alert alert-danger d-none shadow-sm" id="ventaMensajeError"></div>

    <form method="post" id="ventaForm">
        <input type="hidden" asp-for="Venta.IdCliente" id="Venta_IdCliente" />

        <div class="sale-shell">
            <div class="sale-card">
                <section class="sale-section">
                    <div class="d-flex justify-content-between gap-3 flex-wrap mb-3">
                        <div>
                            <span class="section-kicker">Cliente</span>
                            <h5 class="fw-bold mb-1">Datos de facturacion</h5>
                            <p class="text-muted mb-0">Elige consumidor final o busca un cliente registrado.</p>
                        </div>
                        <button type="button"
                                class="btn btn-outline-success"
                                data-bs-toggle="modal"
                                data-bs-target="#modalClienteRapido">
                            Agregar cliente
                        </button>
                    </div>

                    <div class="option-grid mb-3">
                        <button type="button" class="choice-card active" id="btnConsumidorFinal">
                            <span class="title">Consumidor final</span>
                            <span class="hint">Completa NIT y razon social automaticamente.</span>
                        </button>
                        <button type="button" class="choice-card" id="btnClienteRegistrado">
                            <span class="title">Cliente registrado</span>
                            <span class="hint">Busca por NIT o razon social.</span>
                        </button>
                    </div>

                    <div class="row g-3 align-items-start">
                        <div class="col-lg-7 position-relative" id="clienteBusquedaWrap">
                            <label for="clienteBusqueda" class="form-label fw-semibold">Buscar cliente</label>
                            <input type="text"
                                   id="clienteBusqueda"
                                   class="form-control"
                                   autocomplete="off"
                                   placeholder="NIT o razon social" />
                            <div id="clienteResultados" class="list-group position-absolute shadow-sm z-3 search-results"></div>
                            <div class="cliente-status mt-2" id="clienteSeleccionado"></div>
                            <div class="validation-message mt-1 d-none" id="clienteError"></div>
                        </div>
                        <div class="col-lg-5" id="metodoPagoWrap">
                            <label asp-for="Venta.MetodoPago" class="form-label fw-semibold">Metodo de pago</label>
                            <select asp-for="Venta.MetodoPago" class="form-select payment-field" id="Venta_MetodoPago" required>
                                <option value="">Seleccionar</option>
                                <option value="Efectivo">Efectivo</option>
                                <option value="QR">QR</option>
                            </select>
                            <div class="validation-message mt-1 d-none" id="pagoError"></div>
                        </div>
                    </div>
                </section>

                <section class="sale-section">
                    <div class="d-flex justify-content-between gap-3 flex-wrap mb-3">
                        <div>
                            <span class="section-kicker">Medicamentos</span>
                            <h5 class="fw-bold mb-1">Detalle de la venta</h5>
                        </div>
                    </div>

                    <div class="add-medicine-row">
                        <div class="position-relative">
                            <label for="medicamentoBusqueda" class="form-label fw-semibold">Buscar medicamento</label>
                            <input type="text"
                                   id="medicamentoBusqueda"
                                   class="form-control"
                                   autocomplete="off"
                                   placeholder="Nombre o presentacion" />
                            <div id="medicamentoResultados" class="list-group position-absolute shadow-sm z-3 search-results"></div>
                            <div class="validation-message mt-1 d-none" id="medicamentoError"></div>
                        </div>
                        <button type="button" class="btn btn-success" id="agregarDetalle">
                            Agregar
                        </button>
                    </div>

                    <div class="table-responsive mt-4">
                        <table class="table align-middle mb-0" id="detalleVenta">
                            <thead class="table-success">
                                <tr>
                                    <th>Medicamento</th>
                                    <th style="width:120px">Stock</th>
                                    <th style="width:140px">Cantidad</th>
                                    <th style="width:140px">Precio</th>
                                    <th style="width:140px">Subtotal</th>
                                    <th style="width:90px"></th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>

                    <div class="empty-detail mt-3" id="detalleVacio">
                        Aun no agregaste medicamentos a la venta.
                    </div>
                    <div class="validation-message mt-2 d-none" id="detalleError"></div>
                </section>

                <div class="sale-actions">
                    <div>
                        <div class="text-muted fw-semibold">Total de la venta</div>
                        <div class="sale-total">Bs <span id="totalVenta">0.00</span></div>
                    </div>
                    <div class="d-flex gap-2 flex-wrap justify-content-end">
                        <a asp-page="/Ventas/Venta" class="btn btn-secondary btn-lg">Cancelar</a>
                        <button type="button" class="btn btn-success btn-lg px-4" id="btnPrepararVenta">
                            Registrar venta
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="modalConfirmarVenta" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content shadow">
                    <div class="modal-header bg-success text-white">
                        <h5 class="modal-title">Confirmar venta</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-1">Revise los datos antes de registrar la venta.</p>
                        <p class="mb-1">Cliente: <strong id="clienteConfirmacion">Consumidor Final</strong></p>
                        <p class="mb-1">Pago: <strong id="pagoConfirmacion">Sin seleccionar</strong></p>
                        <p class="fw-bold mb-0">Total: Bs <span id="totalConfirmacion">0.00</span></p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-success">Confirmar venta</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="modal fade" id="modalClienteRapido" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">
            <form id="clienteRapidoForm">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Agregar cliente</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger d-none" id="clienteRapidoError"></div>
                    <div class="mb-3">
                        <label for="clienteModalNit" class="form-label">NIT / CI</label>
                        <input id="clienteModalNit" name="clienteModalNit" class="form-control" maxlength="20" required />
                    </div>
                    <div class="mb-3">
                        <label for="clienteModalRazonSocial" class="form-label">Razon social</label>
                        <input id="clienteModalRazonSocial" name="clienteModalRazonSocial" class="form-control" maxlength="80" required />
                    </div>
                    <div>
                        <label for="clienteModalCorreoElectronico" class="form-label">Correo electronico</label>
                        <input id="clienteModalCorreoElectronico" name="clienteModalCorreoElectronico" type="email" class="form-control" maxlength="80" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success" id="btnGuardarClienteRapido">Guardar cliente</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.nuevaVentaData = {
            clientes: @Html.Raw(clientesJson),
            medicamentos: @Html.Raw(medicamentosJson)
        };
    </script>
    <script src="~/js/ventas/nueva-venta.js" asp-append-version="true"></script>
}
