@page
@model FrontendVCare.Pages.Account.DetallesCuentaModel
@{
    ViewData["Title"] = "Detalles de Cuenta";
}

@if (Model.MensajeError != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @Model.MensajeError
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="profile-container">
    <!-- Header Hero -->
    <section class="profile-header">
        <div class="container">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h1 class="profile-title">Detalles de Cuenta</h1>
                    <p class="profile-subtitle">Gestiona tu información personal</p>
                </div>
                <div class="profile-avatar">
                    <div class="avatar-circle">
                        <i class="bi bi-person-fill"></i>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Navigation Tabs -->
    <!-- REMOVED: Navigation tabs are no longer needed -->

    <!-- Main Content -->
    <section class="profile-content py-5">
        <div class="container">
            <!-- Section: Datos de Identidad -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="detail-card">
                        <div class="detail-card-header">
                            <div class="detail-card-icon">
                                <i class="bi bi-person-badge"></i>
                            </div>
                            <div>
                                <h3 class="detail-card-title">Datos de Identidad</h3>
                                <p class="detail-card-subtitle">Tu información de identificación personal</p>
                            </div>
                        </div>
                        <div class="detail-card-body">
                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    <div class="detail-field">
                                        <label class="detail-label">
                                            <i class="bi bi-person"></i> Nombre de Usuario
                                        </label>
                                        <div class="detail-value">@(Model.Usuario ?? "No disponible")</div>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <div class="detail-field">
                                        <label class="detail-label">
                                            <i class="bi bi-fonts"></i> Nombres
                                        </label>
                                        <div class="detail-value">@(Model.Nombres ?? "No disponible")</div>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <div class="detail-field">
                                        <label class="detail-label">
                                            <i class="bi bi-chat-left"></i> Primer Apellido
                                        </label>
                                        <div class="detail-value">@(Model.ApellidoPaterno ?? "No disponible")</div>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <div class="detail-field">
                                        <label class="detail-label">
                                            <i class="bi bi-chat-left"></i> Segundo Apellido
                                        </label>
                                        <div class="detail-value">@(Model.ApellidoMaterno ?? "No disponible")</div>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <div class="detail-field">
                                        <label class="detail-label">
                                            <i class="bi bi-card-text"></i> Cédula de Identidad
                                        </label>
                                        <div class="detail-value">@(Model.CI ?? "No disponible")</div>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <div class="detail-field">
                                        <label class="detail-label">
                                            <i class="bi bi-geo-alt"></i> Expedido en
                                        </label>
                                        <div class="detail-value">@(Model.CiExtencion ?? "No disponible")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section: Datos de Contacto -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="detail-card">
                        <div class="detail-card-header">
                            <div class="detail-card-icon">
                                <i class="bi bi-telephone"></i>
                            </div>
                            <div>
                                <h3 class="detail-card-title">Datos de Contacto</h3>
                                <p class="detail-card-subtitle">Tu email y teléfono</p>
                            </div>
                        </div>
                        <div class="detail-card-body">
                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    <div class="detail-field">
                                        <label class="detail-label">
                                            <i class="bi bi-envelope-check"></i> Correo Electrónico
                                        </label>
                                        <div class="detail-value">@(Model.Email ?? "No registrado")</div>
                                        <small class="detail-note">
                                            <i class="bi bi-check-circle-fill"></i> Email verificado
                                        </small>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <div class="detail-field">
                                        <label class="detail-label">
                                            <i class="bi bi-telephone-fill"></i> Teléfono
                                        </label>
                                        <div class="detail-value">
                                            @if (!string.IsNullOrEmpty(Model.Phone))
                                            {
                                                <span>@Model.Phone</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">No registrado</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section: Estado de Cuenta -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <div class="detail-card">
                        <div class="detail-card-header">
                            <div class="detail-card-icon">
                                <i class="bi bi-shield-lock"></i>
                            </div>
                            <div>
                                <h3 class="detail-card-title">Rol</h3>
                                <p class="detail-card-subtitle">Tu función en el sistema</p>
                            </div>
                        </div>
                        <div class="detail-card-body">
                            <div class="detail-field">
                                <div class="role-display">
                                    <span class="role-badge">@(Model.Role ?? "Usuario")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="detail-card">
                        <div class="detail-card-header">
                            <div class="detail-card-icon">
                                <i class="bi bi-check-circle"></i>
                            </div>
                            <div>
                                <h3 class="detail-card-title">Estado de Cuenta</h3>
                                <p class="detail-card-subtitle">Status actual de tu cuenta</p>
                            </div>
                        </div>
                        <div class="detail-card-body">
                            <div class="detail-field">
                                <div class="status-display">
                                    <span class="status-badge status-active">
                                        <span class="status-dot"></span> Activa
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Button -->
            <div class="row">
                <div class="col-12">
                    <div class="section-actions">
                        <button type="button" class="btn btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#editProfileModal">
                            <i class="bi bi-pencil-square"></i> Editar Información
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<!-- Edit Profile Modal -->
<div class="modal fade" id="editProfileModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-pencil-square"></i> Editar Información
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post">
                <div class="modal-body">
                    @if (Model.UsuarioActualizar != null)
                    {
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="Nombres" class="form-label">Nombres</label>
                                <input type="text" class="form-control" asp-for="UsuarioActualizar.Nombres" placeholder="Tu nombre" required>
                                <span class="text-danger" asp-validation-for="UsuarioActualizar.Nombres"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="ApellidoPaterno" class="form-label">Primer Apellido</label>
                                <input type="text" class="form-control" asp-for="UsuarioActualizar.ApellidoPaterno" placeholder="Primer apellido" required>
                                <span class="text-danger" asp-validation-for="UsuarioActualizar.ApellidoPaterno"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="ApellidoMaterno" class="form-label">Segundo Apellido</label>
                                <input type="text" class="form-control" asp-for="UsuarioActualizar.ApellidoMaterno" placeholder="Segundo apellido">
                                <span class="text-danger" asp-validation-for="UsuarioActualizar.ApellidoMaterno"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="Email" class="form-label">Correo Electrónico</label>
                                <input type="email" class="form-control" asp-for="UsuarioActualizar.Email" placeholder="tu.email@ejemplo.com" required>
                                <span class="text-danger" asp-validation-for="UsuarioActualizar.Email"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="Telefono" class="form-label">Teléfono</label>
                                <input type="tel" class="form-control" asp-for="UsuarioActualizar.Telefono" placeholder="71234567">
                                <span class="text-danger" asp-validation-for="UsuarioActualizar.Telefono"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="Ci" class="form-label">Cédula de Identidad</label>
                                <input type="text" class="form-control" asp-for="UsuarioActualizar.Ci" placeholder="C.I." required>
                                <span class="text-danger" asp-validation-for="UsuarioActualizar.Ci"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="CiExtencion" class="form-label">Expedido en</label>
                                <input type="text" class="form-control" asp-for="UsuarioActualizar.CiExtencion" placeholder="Ex: LP, CB, SC">
                                <span class="text-danger" asp-validation-for="UsuarioActualizar.CiExtencion"></span>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
