@page
@model FrontendVCare.Pages.Account.SeguridadModel
@{
    ViewData["Title"] = "Seguridad";
}

@if (Model.PasswordError != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @Model.PasswordError
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="profile-container">
    <!-- Header Hero -->
    <section class="profile-header">
        <div class="container">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h1 class="profile-title">Seguridad</h1>
                    <p class="profile-subtitle">Protege tu cuenta y datos personales</p>
                </div>
                <div class="profile-avatar">
                    <div class="avatar-circle">
                        <i class="bi bi-lock-fill"></i>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <section class="profile-content py-5">
        <div class="container">
            <div class="section-card">
                <div class="section-header">
                    <h2>Opciones de Seguridad</h2>
                    <p class="section-subtitle">Administra la seguridad de tu cuenta</p>
                </div>

                <!-- Password Change Section -->
                <div class="security-item">
                    <div class="security-info">
                        <h4>Contraseña</h4>
                        <p class="text-muted mb-0">Cambia tu contraseña para mantener tu cuenta segura</p>
                    </div>
                    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#changePasswordModal">
                        <i class="bi bi-pencil"></i> Cambiar Contraseña
                    </button>
                </div>

                <hr class="my-4">

                <!-- Two-Factor Authentication -->
                <div class="security-item">
                    <div class="security-info">
                        <h4>Autenticación de Dos Factores</h4>
                        <p class="text-muted mb-0">Añade una capa adicional de seguridad a tu cuenta</p>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="twoFactorSwitch" disabled>
                        <label class="form-check-label" for="twoFactorSwitch">
                            No disponible aún
                        </label>
                    </div>
                </div>

                <hr class="my-4">

                <!-- Active Sessions -->
                <div class="security-item">
                    <div class="security-info">
                        <h4>Sesiones Activas</h4>
                        <p class="text-muted mb-0">Dispositivos con acceso a tu cuenta</p>
                    </div>
                    <button type="button" class="btn btn-outline-danger btn-sm" disabled>
                        Cerrar Todas las Sesiones
                    </button>
                </div>
            </div>
        </div>
    </section>
</div>

<!-- Change Password Modal -->
<div class="modal fade" id="changePasswordModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-lock-fill"></i> Cambiar Contraseña
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="ChangePassword">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="currentPassword" class="form-label">Contraseña Actual</label>
                        <div class="input-group">
                            <input type="password" id="currentPassword" name="currentPassword" class="form-control" placeholder="Tu contraseña actual" required>
                            <button class="btn btn-outline-secondary" type="button" id="toggleCurrent" tabindex="-1">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="newPassword" class="form-label">Nueva Contraseña</label>
                        <div class="input-group">
                            <input type="password" id="newPassword" name="newPassword" class="form-control" placeholder="Tu nueva contraseña" required>
                            <button class="btn btn-outline-secondary" type="button" id="toggleNew" tabindex="-1">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <small id="passwordHint" class="form-text" style="display: none; color: #dc3545; margin-top: 0.25rem;"></small>
                    </div>

                    <div class="mb-3">
                        <label for="confirmPassword" class="form-label">Confirmar Contraseña</label>
                        <div class="input-group">
                            <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" placeholder="Confirma tu nueva contraseña" required>
                            <button class="btn btn-outline-secondary" type="button" id="toggleConfirm" tabindex="-1">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <small id="matchHint" class="form-text" style="display: none; color: #dc3545; margin-top: 0.25rem;"></small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" id="submitPasswordBtn" disabled>
                        <i class="bi bi-check-lg"></i> Cambiar Contraseña
                    </button>
                </div>
            </form>

            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    const currentPasswordInput = document.getElementById('currentPassword');
                    const newPasswordInput = document.getElementById('newPassword');
                    const confirmPasswordInput = document.getElementById('confirmPassword');
                    const toggleCurrentBtn = document.getElementById('toggleCurrent');
                    const toggleNewBtn = document.getElementById('toggleNew');
                    const toggleConfirmBtn = document.getElementById('toggleConfirm');
                    const passwordHint = document.getElementById('passwordHint');
                    const matchHint = document.getElementById('matchHint');
                    const submitBtn = document.getElementById('submitPasswordBtn');
                    
                    const requirements = {
                        length: { regex: /.{8,}/, text: 'Al menos 8 caracteres' },
                        uppercase: { regex: /[A-Z]/, text: 'Una letra mayúscula' },
                        lowercase: { regex: /[a-z]/, text: 'Una letra minúscula' },
                        number: { regex: /\d/, text: 'Al menos un número' }
                    };

                    // Toggle visibility functions
                    function togglePasswordVisibility(input, btn) {
                        const isPassword = input.type === 'password';
                        input.type = isPassword ? 'text' : 'password';
                        
                        const icon = btn.querySelector('i');
                        if (isPassword) {
                            icon.classList.remove('bi-eye');
                            icon.classList.add('bi-eye-slash');
                        } else {
                            icon.classList.remove('bi-eye-slash');
                            icon.classList.add('bi-eye');
                        }
                    }

                    toggleCurrentBtn.addEventListener('click', (e) => {
                        e.preventDefault();
                        togglePasswordVisibility(currentPasswordInput, toggleCurrentBtn);
                    });

                    toggleNewBtn.addEventListener('click', (e) => {
                        e.preventDefault();
                        togglePasswordVisibility(newPasswordInput, toggleNewBtn);
                    });

                    toggleConfirmBtn.addEventListener('click', (e) => {
                        e.preventDefault();
                        togglePasswordVisibility(confirmPasswordInput, toggleConfirmBtn);
                    });

                    function validatePassword(password) {
                        const failed = [];
                        
                        Object.keys(requirements).forEach(key => {
                            if (!requirements[key].regex.test(password)) {
                                failed.push(requirements[key].text);
                            }
                        });
                        
                        return failed;
                    }

                    function updateValidation() {
                        const password = newPasswordInput.value;
                        const confirmPassword = confirmPasswordInput.value;
                        const failed = validatePassword(password);
                        
                        // Update password strength hint
                        if (password.length === 0) {
                            passwordHint.style.display = 'none';
                            newPasswordInput.classList.remove('is-invalid', 'is-valid');
                        } else if (failed.length > 0) {
                            passwordHint.textContent = 'Falta: ' + failed.join(', ');
                            passwordHint.style.display = 'block';
                            newPasswordInput.classList.add('is-invalid');
                            newPasswordInput.classList.remove('is-valid');
                        } else {
                            passwordHint.style.display = 'none';
                            newPasswordInput.classList.add('is-valid');
                            newPasswordInput.classList.remove('is-invalid');
                        }
                        
                        // Update password match hint
                        if (password.length > 0 && confirmPassword.length > 0 && password !== confirmPassword) {
                            matchHint.textContent = 'Las contraseñas no coinciden';
                            matchHint.style.display = 'block';
                            confirmPasswordInput.classList.add('is-invalid');
                        } else if (confirmPassword.length > 0 && password === confirmPassword) {
                            matchHint.style.display = 'none';
                            confirmPasswordInput.classList.remove('is-invalid');
                            confirmPasswordInput.classList.add('is-valid');
                        } else {
                            matchHint.style.display = 'none';
                            confirmPasswordInput.classList.remove('is-invalid', 'is-valid');
                        }
                        
                        // Enable/disable submit button
                        submitBtn.disabled = !(failed.length === 0 && password === confirmPassword && password.length > 0);
                    }

                    newPasswordInput.addEventListener('input', updateValidation);
                    confirmPasswordInput.addEventListener('input', updateValidation);
                });
            </script>
        </div>
    </div>
</div>
