@page
@model FrontendVCare.Pages.Usuario.UsuarioCreateModel
@{
    ViewData["Title"] = "Nuevo Registro - VitalCare";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card shadow border-0">
                <div class="card-header text-center bg-success text-white py-3">
                    <h2 class="mb-0 fw-bold text-white">
                        Registro de Usuario
                    </h2>
                    <p class="mb-0 small">Las credenciales se generarán y enviarán automáticamente</p>
                </div>

                <div class="card-body p-4">
                    <form method="post" asp-page-handler="CrearUsuario" class="row g-3">

                        <div class="col-md-12 form-floating mb-1">
                            <input asp-for="Input.Nombres" class="form-control" placeholder="Nombre" />
                            <label class="ms-2">Nombres</label>
                        </div>

                        <div class="col-md-6 form-floating">
                            <input asp-for="Input.ApellidoPaterno" class="form-control" placeholder="Primer Apellido" />
                            <label class="ms-2">Primer Apellido</label>
                        </div>

                        <div class="col-md-6 form-floating">
                            <input asp-for="Input.ApellidoMaterno" class="form-control" placeholder="Segundo Apellido" />
                            <label class="ms-2">Segundo Apellido (opcional)</label>
                        </div>

                        <div class="col-md-5 form-floating">
                            <input asp-for="Input.Ci" class="form-control" placeholder="CI" maxlength="8" />
                            <label class="ms-2">C.I.</label>
                            <small class="text-muted">CI: Ej. 12345678</small>
                        </div>

                        <div class="col-md-3 form-floating">
                            <input asp-for="CiComplemento" class="form-control" placeholder="Complemento" maxlength="2" />
                            <label class="ms-2">Complemento</label>
                            <small class="text-muted">Opcional. Ej. 1A</small>
                        </div>

                        <div class="col-md-4 form-floating">
                            <select asp-for="Input.CiExtencion" class="form-select">
                                <option value="">Seleccione</option>
                                <option value="BE">Beni</option>
                                <option value="CB">Cochabamba</option>
                                <option value="CH">Chuquisaca</option>
                                <option value="LP">La Paz</option>
                                <option value="OR">Oruro</option>
                                <option value="PD">Pando</option>
                                <option value="PT">Potosí</option>
                                <option value="SC">Santa Cruz</option>
                                <option value="TJ">Tarija</option>
                            </select>
                            <label asp-for="Input.CiExtencion">Expedido en</label>
                        </div>

                        <div class="col-md-4 form-floating">
                            <input asp-for="Input.Telefono" class="form-control" placeholder="Telf" maxlength="8" />
                            <label class="ms-2">Teléfono</label>
                        </div>

                        <div class="col-md-8 form-floating">
                            <input asp-for="Input.Email" type="email" class="form-control" placeholder="Email" />
                            <label class="ms-2">Correo Electrónico oficial</label>
                        </div>

                        <div class="col-md-4 form-floating">
                            <select asp-for="Input.Role" class="form-select">
                                <option value="Bioquimico">Bioquímico</option>
                                <option value="Admin">Administrador</option>
                            </select>
                            <label class="ms-2">Tipo de acceso</label>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.Estado.MensajeError))
                        {
                            <div class="col-12">
                                <div class="alert alert-danger mb-0">@Model.Estado.MensajeError</div>
                            </div>
                        }
                        else if (!ViewContext.ModelState.IsValid)
                        {
                            <div class="col-12">
                                <div class="alert alert-danger mb-0">
                                    @{
                                        string[] ordenCampos =
                                        [
                                            "Input.Nombres",
                                            "Input.ApellidoPaterno",
                                            "Input.ApellidoMaterno",
                                            "Input.Ci",
                                            "CiComplemento",
                                            "Input.CiExtencion",
                                            "Input.Telefono",
                                            "Input.Email",
                                            "Input.Role"
                                        ];

                                        string primerError = "Error de validación.";

                                        foreach (string campo in ordenCampos)
                                        {
                                            if (ViewContext.ModelState.TryGetValue(campo, out var entry)
                                                && entry.Errors.Count > 0)
                                            {
                                                primerError = entry.Errors.First().ErrorMessage;
                                                break;
                                            }
                                        }

                                        @primerError
                                    }
                                </div>
                            </div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <a asp-page="Usuario" class="btn btn-secondary px-4">Cancelar</a>
                            <button type="submit" class="btn btn-success px-5 fw-bold">
                                Generar y Registrar
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>